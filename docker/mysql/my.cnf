[mysqld]
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
# MySQL 8.4 removed default-authentication-plugin / default_authentication_plugin.
# PHP 8.x + Laravel work with the default caching_sha2_password.
innodb_buffer_pool_size = 256M
max_connections = 100
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow.log
long_query_time = 2

[client]
default-character-set = utf8mb4
