# =============================================================
# Dayflow — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to version control!
# =============================================================

# ---- App ----
APP_NAME=Dayflow
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ---- Database ----
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=dayflow
DB_USERNAME=dayflow
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root_secret

# ---- Google OAuth ----
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ---- Corporate Email Domain Restriction ----
# Only users from this domain can log in.
ALLOWED_EMAIL_DOMAIN=uello.com.br

# ---- Slack Notifications ----
# Incoming Webhook URL from Slack App configuration
# Leave empty to disable Slack notifications
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#general

# ---- Vacation Conflict Settings ----
# Maximum percentage of a team that can be on vacation simultaneously (0-100)
VACATION_CONFLICT_THRESHOLD_PERCENT=30

# ---- Session / Auth ----
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SANCTUM_STATEFUL_DOMAINS=localhost:5173
# Login email/senha para testes (POST /api/auth/dev-login). Use false em produção.
DEV_PASSWORD_LOGIN=true

# ---- Cache / Queue ----
CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# ---- Mail (optional for future use) ----
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@uello.com.br"
MAIL_FROM_NAME="Dayflow"

# ---- Logging ----
LOG_CHANNEL=stack
LOG_LEVEL=debug
